# ─── Required ─────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
# LOG_LEVEL: 0=DEBUG 1=INFO 2=WARN 3=ERROR (default: 1)
LOG_LEVEL=1

# ─── Storage ──────────────────────────────────────────────────────────────────
IMAGE_STORAGE_PATH=./storage/images

# ─── Database ─────────────────────────────────────────────────────────────────
# Driver: "sqlite" (no external DB needed) or "postgres"
DB_DRIVER=sqlite

# SQLite — used when DB_DRIVER=sqlite
DB_SQLITE_PATH=./data/liift.db

# PostgreSQL — used when DB_DRIVER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=liift
DB_SSLMODE=disable

# Connection pool (postgres only)
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_MAX_LIFETIME=300

# ─── Docker self-hosting quickstart ───────────────────────────────────────────
# 1. cp .env.example .env
# 2. Set JWT_SECRET (openssl rand -hex 32)
# 3. docker compose up
#
# For PostgreSQL instead of SQLite:
#   docker compose -f docker-compose.yml -f docker-compose.postgres.yml up
